DirectoryIndex index.php

RewriteEngine On
RewriteBase /site

# Redirect /index.html or /index.php to /
RewriteCond %{THE_REQUEST} \s/+index\.(html|php)[\s?] [NC]
RewriteRule ^index\.(html|php)$ / [R=301,L]

# Redirect any .html or .php URL to extensionless URL
RewriteCond %{THE_REQUEST} \s/+(.+?)\.(html|php)[\s?] [NC]
RewriteRule ^ %1 [R=301,L,NE]

# Load matching .php file for extensionless URL
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.+?)/?$ $1.php [L,QSA]

# Temporary fallback for old .html pages not yet converted
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+?)/?$ $1.html [L,QSA]
